generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nomeCompleto       String
  cpfCnpj            String?
  rg                 String?
  dataNascimento     DateTime?     @db.Date
  email              String?
  telefonePrincipal  String
  telefoneSecundario String?
  telefoneWhatsapp   String?
  tipoPessoa         String?       @default("PF")
  cep                String?
  logradouro         String?
  numero             String?
  bairro             String?
  cidade             String?
  uf                 String?
  pontoReferencia    String?
  latitude           Float?
  longitude          Float?
  canalEntrada       String?
  campanha           String?
  vendedorId         String?       @db.Uuid
  tipoCliente        String?       @default("RESIDENCIAL")
  statusProposta     String?       @default("PENDENTE")
  createdAt          DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  tenant_id          String?       @db.Uuid
  tenants            Tenant?       @relation(fields: [tenant_id], references: [id])
  appointments       Appointment[]
  contratos          ContratoAssinatura[]
}

model Assinante {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String
  cpfCnpj   String  @unique
  metadata  Json?
  status    String  @default("ATIVO")
  tenant_id String? @db.Uuid

  enderecos     Endereco[]
  contatos      Contato[]
  faturas       Fatura[]
  ordensServico OrdemServico[]
  svas          AssinanteSVA[]
  contratos     ContratoAssinatura[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  tenants   Tenant?  @relation(fields: [tenant_id], references: [id])
}

model Endereco {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  logradouro  String
  numero      String
  bairro      String
  cidade      String
  estado      String
  cep         String
  complemento String?
  tipo        String    @default("COBRANCA")
}

model Contato {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  tipo        String
  valor       String
}

model Fatura {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  valor       Decimal   @db.Decimal(10, 2)
  vencimento  DateTime  @db.Timestamptz(6)
  status      String    @default("PENDENTE")
  tenant_id   String?   @db.Uuid
  tenants     Tenant?   @relation(fields: [tenant_id], references: [id])

  pagamento  Pagamento?
  notaFiscal NotaFiscal?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Pagamento {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faturaId String   @unique @db.Uuid
  fatura   Fatura   @relation(fields: [faturaId], references: [id])
  metodo   String
  data     DateTime @default(now()) @db.Timestamptz(6)
  valor    Decimal  @db.Decimal(10, 2)
}

model OrdemServico {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId     String    @db.Uuid
  assinante       Assinante @relation(fields: [assinanteId], references: [id])
  tecnicoId       String?   @db.Uuid
  tecnico         User?     @relation(fields: [tecnicoId], references: [id])
  tipo            String
  status          String    @default("ABERTA")
  descricao       String
  prioridade      String    @default("MEDIA")
  dataAgendamento DateTime? @db.Timestamptz(6)
  tenant_id       String?   @db.Uuid
  conversation_id String?   @db.Uuid
  occurrence_id   String?   @db.Uuid

  conversation Conversation?         @relation(fields: [conversation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  occurrence   customer_occurrences? @relation(fields: [occurrence_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants      Tenant?               @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model OLT {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome       String
  ip         String @unique
  modelo     String
  comunidade String @default("public")
  tenant_id  String? @db.Uuid
  tenants    Tenant? @relation(fields: [tenant_id], references: [id])

  onus ONU[]
}

model ONU {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  oltId     String  @db.Uuid
  olt       OLT     @relation(fields: [oltId], references: [id])
  serial    String  @unique
  ponPort   Int
  status    String  @default("OFFLINE")
  tenant_id String? @db.Uuid
  tenants   Tenant? @relation(fields: [tenant_id], references: [id])
}

model NotaFiscal {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faturaId String @unique @db.Uuid
  fatura   Fatura @relation(fields: [faturaId], references: [id])
  numero   String
  status   String @default("EMITIDA")
}

model AssinanteSVA {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  svaName     String
  status      String    @default("ATIVO")
}

model Conversation {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contact_name    String
  contact_phone   String?
  platform        String?        @default("whatsapp")
  status          String?        @default("new")
  last_message    String?
  last_message_at DateTime?      @default(now()) @db.Timestamptz(6)
  ai_active       Boolean?       @default(false)
  is_closed       Boolean?       @default(false)
  unread_count    Int?           @default(0)
  assigned_to     String?
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  tenant_id       String?        @db.Uuid
  occurrence_id   String?        @db.Uuid
  tenants         Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages        Message[]
  ordens_servico  OrdemServico[]

  @@map("conversations")
}

model Message {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String?       @db.Uuid
  sender          String
  text            String
  is_user         Boolean?      @default(false)
  is_bot          Boolean?      @default(false)
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("messages")
}

model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id   String?   @db.Uuid
  tenant_id  String?   @db.Uuid
  action     String
  resource   String
  details    Json?     @default("{}")
  ip_address String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  User       User?     @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants    Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("audit_logs")
}

model customer_occurrences {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  protocol           String?        @unique
  customer_name      String
  subject            String?
  status             String?
  opening_date       DateTime?      @default(now()) @db.Timestamptz(6)
  description        String?
  tenant_id          String?        @db.Uuid
  ordens_servico     OrdemServico[]
}

model invitations {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String?   @db.Uuid
  email        String    @unique
  invite_token String    @unique
  role         String?   @default("VENDEDOR")
  created_by   String?   @db.Uuid
  used_at      DateTime? @db.Timestamptz(6)
  expires_at   DateTime? @db.Timestamptz(6)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  tenants      Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Profile {
  id          String    @id @db.Uuid
  tenant_id   String?   @db.Uuid
  full_name   String?
  email       String?
  role        String?   @default("VENDEDOR")
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  tenants     Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("profiles")
}

model User {
  id        String     @id @db.Uuid
  email     String?
  auditLogs AuditLog[]
  orders    OrdemServico[]
}

model Tenant {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  slug               String               @unique
  plan               String?              @default("FREE")
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  Lead               Lead[]
  audit_logs         AuditLog[]
  conversations      Conversation[]
  invitations        invitations[]
  profiles           Profile[]
  ordens_servico     OrdemServico[]
  olts               OLT[]
  onus               ONU[]
  assinantes         Assinante[]
  faturas            Fatura[]

  @@map("tenants")
}

model Appointment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId             String?   @db.Uuid
  tipo               String
  titulo             String
  dataInicio         DateTime  @db.Timestamptz(6)
  dataFim                DateTime? @db.Timestamptz(6)
  status                 String    @default("AGENDADO")
  createdAt              DateTime? @default(now()) @db.Timestamptz(6)
  Lead                   Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ContratoAssinatura {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId         String?   @db.Uuid
  assinanteId    String?   @db.Uuid
  status         String    @default("PENDENTE")
  token          String    @unique
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  Lead           Lead?     @relation(fields: [leadId], references: [id])
  Assinante      Assinante? @relation(fields: [assinanteId], references: [id])
}
