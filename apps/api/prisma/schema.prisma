generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model Lead {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nomeCompleto          String
  cpfCnpj               String?
  rg                    String?
  dataNascimento        DateTime?     @db.Date
  email                 String?
  telefonePrincipal     String
  telefoneSecundario    String?
  telefoneWhatsapp      String?
  tipoPessoa            String?       @default("PF")
  cep                   String?
  logradouro            String?
  numero                String?
  bairro                String?
  cidade                String?
  uf                    String?
  pontoReferencia       String?
  latitude              Float?
  longitude             Float?
  canalEntrada          String?
  campanha              String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmTerm               String?
  utmContent            String?
  indicador             String?
  ipEntrada             String?
  dispositivo           String?
  vendedorId            String?       @db.Uuid
  tipoCliente           String?       @default("RESIDENCIAL")
  perfilUso             String?
  usoPrincipal          String?
  numDispositivos       Int?
  temMEI                Boolean?      @default(false)
  scoreQualificacao     Int?          @default(0)
  interesseDeclarado    String?
  interessePlano        String?
  valorPagoAtual        Decimal?      @db.Decimal(10, 2)
  operadoraAtual        String?
  statusQualificacao    String?       @default("PENDENTE")
  statusViabilidade     String?       @default("PENDENTE")
  distanciaDistribuidor Float?
  ctoProxima            String?
  portasDisponiveis     Int?
  obsTecnica            String?
  verificadoPor         String?
  dataVerificacao       DateTime?     @db.Timestamptz(6)
  statusProposta        String?
  valorProposta         Decimal?      @db.Decimal(10, 2)
  linkContrato          String?
  dataAceite            DateTime?     @db.Timestamptz(6)
  dataInstalacao        DateTime?     @db.Timestamptz(6)
  turnoInstalacao       String?
  tecnicoId             String?       @db.Uuid
  numeroOS              String?
  observacoes           String?
  perfilComercial       String?
  decisorIdentificado   Boolean?      @default(false)
  melhorHorario         String?
  tentativasContato     Int?          @default(0)
  dataProximoContato    DateTime?     @db.Timestamptz(6)
  dataUltimaInteracao   DateTime?     @default(now()) @db.Timestamptz(6)
  isFrio                Boolean?      @default(false)
  dataEntrada           DateTime?     @default(now()) @db.Timestamptz(6)
  createdAt             DateTime?     @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime?     @default(now()) @updatedAt @db.Timestamptz(6)
  stageId               String?       @db.Uuid
  status_agendamento    String?       @default("AGENDADO")
  tenant_id             String?       @default(dbgenerated("get_tenant_id()")) @db.Uuid
  Appointment           Appointment[]
  tenants               Tenant?       @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model User {
  id                         String                 @id @db.Uuid
  instance_id                String?                @db.Uuid
  aud                        String?                @db.VarChar(255)
  role                       String?                @db.VarChar(255)
  email                      String?                @db.VarChar(255)
  email_confirmed_at         DateTime?              @db.Timestamptz(6)
  invited_at                 DateTime?              @db.Timestamptz(6)
  confirmation_token         String?                @db.VarChar(255)
  confirmation_sent_at       DateTime?              @db.Timestamptz(6)
  recovery_token             String?                @db.VarChar(255)
  recovery_sent_at           String?                @db.VarChar(255)
  email_change_token_new     String?                @db.VarChar(255)
  email_change_token_current String?                @db.VarChar(255)
  email_change_sent_at       DateTime?              @db.Timestamptz(6)
  last_sign_in_at            DateTime?              @db.Timestamptz(6)
  raw_app_meta_data          Json?
  raw_user_meta_data         Json?
  is_super_admin             Boolean?
  created_at                 DateTime?              @db.Timestamptz(6)
  updated_at                 DateTime?              @db.Timestamptz(6)
  phone                      String?                @unique
  phone_confirmed_at         DateTime?              @db.Timestamptz(6)
  phone_change_token         String?                @default("") @db.VarChar(255)
  phone_change_sent_at       DateTime?              @db.Timestamptz(6)
  confirmed_at               DateTime?              @default(dbgenerated("LEAST(email_confirmed_at, phone_confirmed_at)")) @db.Timestamptz(6)
  email_change               String?                @default("") @db.VarChar(255)
  password_hash              String?                @default("") @db.VarChar(255)
  reauthentication_token     String?                @default("") @db.VarChar(255)
  reauthentication_sent_at   DateTime?              @db.Timestamptz(6)
  is_sso_user                Boolean                @default(false)
  deleted_at                 DateTime?              @db.Timestamptz(6)
  is_anonymous               Boolean                @default(false)
  identities                 identities[]
  mfa_factors                mfa_factors[]
  sessions                   sessions[]
  one_time_tokens            one_time_tokens[]
  Profile                    Profile?
  AuditLog                   AuditLog[]
  invitations                invitations[]
  remote_access_keys         remote_access_keys[]
  assignedOS                 OrdemServico[]         @relation("TecnicoOS")
  oauth_authorizations       oauth_authorizations[]
  oauth_consents             oauth_consents[]
  webauthn_challenges        webauthn_challenges[]
  webauthn_credentials       webauthn_credentials[]

  @@index([instance_id])
  @@map("users")
  @@schema("auth")
}

model Assinante {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String
  cpfCnpj   String  @unique
  metadata  Json?
  status    String  @default("ATIVO")
  tenant_id String? @db.Uuid

  enderecos     Endereco[]
  contatos      Contato[]
  faturas       Fatura[]
  ordensServico OrdemServico[]
  svas          AssinanteSVA[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  tenants   Tenant?  @relation(fields: [tenant_id], references: [id])

  @@schema("public")
}

model Endereco {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  logradouro  String
  numero      String
  bairro      String
  cidade      String
  estado      String
  cep         String
  complemento String?
  tipo        String    @default("COBRANCA")
  latitude    Float?
  longitude   Float?

  @@schema("public")
}

model Contato {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  tipo        String
  valor       String

  @@schema("public")
}

model Fatura {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  valor       Decimal   @db.Decimal(10, 2)
  vencimento  DateTime  @db.Timestamptz(6)
  status      String    @default("PENDENTE")

  pagamento  Pagamento?
  notaFiscal NotaFiscal?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@schema("public")
}

model Pagamento {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faturaId String   @unique @db.Uuid
  fatura   Fatura   @relation(fields: [faturaId], references: [id])
  metodo   String
  data     DateTime @default(now()) @db.Timestamptz(6)
  valor    Decimal  @db.Decimal(10, 2)

  pix PagamentoPix?

  @@schema("public")
}

model PagamentoPix {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pagamentoId String    @unique @db.Uuid
  pagamento   Pagamento @relation(fields: [pagamentoId], references: [id])
  qrCode      String
  txid        String    @unique
  status      String    @default("PENDENTE")

  @@schema("public")
}

model OrdemServico {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId     String    @db.Uuid
  assinante       Assinante @relation(fields: [assinanteId], references: [id])
  tecnicoId       String?   @db.Uuid
  tecnico         User?     @relation("TecnicoOS", fields: [tecnicoId], references: [id])
  tipo            String
  status          String    @default("ABERTA")
  descricao       String
  prioridade      String    @default("MEDIA")
  dataAgendamento DateTime? @db.Timestamptz(6)
  tenant_id       String?   @db.Uuid
  conversation_id String?   @db.Uuid
  occurrence_id   String?   @db.Uuid

  conversation Conversation?         @relation(fields: [conversation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  occurrence   customer_occurrences? @relation(fields: [occurrence_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants      Tenant?               @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@schema("public")
}

model OLT {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome       String
  ip         String @unique
  modelo     String
  comunidade String @default("public")

  onus ONU[]

  @@schema("public")
}

model ONU {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  oltId   String  @db.Uuid
  olt     OLT     @relation(fields: [oltId], references: [id])
  serial  String  @unique
  ponPort Int
  status  String  @default("OFFLINE")
  sinal   String?

  @@schema("public")
}

model NotaFiscal {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faturaId String @unique @db.Uuid
  fatura   Fatura @relation(fields: [faturaId], references: [id])
  numero   String
  xml      String
  status   String @default("EMITIDA")

  @@schema("public")
}

model AssinanteSVA {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assinanteId String    @db.Uuid
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  svaName     String
  status      String    @default("ATIVO")

  @@schema("public")
}

model Conversation {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contact_name    String
  contact_phone   String?
  platform        String?        @default("whatsapp")
  status          String?        @default("new")
  assigned_to     String?
  is_pinned       Boolean?       @default(false)
  is_archived     Boolean?       @default(false)
  is_muted        Boolean?       @default(false)
  is_blocked      Boolean?       @default(false)
  unread_count    Int?           @default(0)
  last_message    String?
  last_message_at DateTime?      @default(now()) @db.Timestamptz(6)
  ai_active       Boolean?       @default(false)
  is_closed       Boolean?       @default(false)
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?      @default(now()) @updatedAt @db.Timestamptz(6)
  contact_email   String?
  tenant_id       String?        @db.Uuid
  occurrence_id   String?        @db.Uuid
  tenants         Tenant?        @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages        Message[]
  ordens_servico  OrdemServico[]

  @@map("conversations")
  @@schema("public")
}

model Message {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String?       @db.Uuid
  sender          String
  text            String
  is_user         Boolean?      @default(false)
  is_bot          Boolean?      @default(false)
  reactions       String[]
  file_url        String?
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  file_name       String?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("messages")
  @@schema("public")
}

model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id   String?   @db.Uuid
  tenant_id  String?   @db.Uuid
  action     String
  resource   String
  details    Json?     @default("{}")
  ip_address String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  User       User?     @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants    Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("audit_logs")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
