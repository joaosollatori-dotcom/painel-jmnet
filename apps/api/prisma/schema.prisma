generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FINANCEIRO
  SUPORTE
  TECNICO
  READONLY
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          Role     @default(SUPORTE)
  permissions   String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedOS    OrdemServico[] @relation("TecnicoOS")
  leads         Lead[]         @relation("VendedorLeads")
}

model Assinante {
  id            String   @id @default(uuid())
  nome          String
  cpfCnpj       String   @unique
  metadata      Json?    // Para conciliação com ERPs externos
  status        String   @default("ATIVO") // ATIVO, BLOQUEADO, CANCELADO
  
  enderecos     Endereco[]
  contatos      Contato[]
  faturas       Fatura[]
  ordensServico OrdemServico[]
  svas          AssinanteSVA[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Endereco {
  id          String    @id @default(uuid())
  assinanteId String
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  logradouro  String
  numero      String
  bairro      String
  cidade      String
  estado      String
  cep         String
  complemento String?
  tipo        String    @default("COBRANCA") // INSTALACAO, COBRANCA
  latitude    Float?
  longitude   Float?
}

model Contato {
  id          String    @id @default(uuid())
  assinanteId String
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  tipo        String    // WHATSAPP, EMAIL, FIXO
  valor       String
}

model Fatura {
  id          String    @id @default(uuid())
  assinanteId String
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  valor       Decimal
  vencimento  DateTime
  status      String    @default("PENDENTE") // PENDENTE, PAGO, CANCELADO, ATRASADO
  
  pagamento   Pagamento?
  notaFiscal  NotaFiscal?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pagamento {
  id        String   @id @default(uuid())
  faturaId  String   @unique
  fatura    Fatura   @relation(fields: [faturaId], references: [id])
  metodo    String   // PIX, BOLETO, CARTAO
  data      DateTime @default(now())
  valor     Decimal
  
  pix       PagamentoPix?
}

model PagamentoPix {
  id          String    @id @default(uuid())
  pagamentoId String    @unique
  pagamento   Pagamento @relation(fields: [pagamentoId], references: [id])
  qrCode      String
  txid        String    @unique
  status      String    @default("PENDENTE")
}

model OrdemServico {
  id          String    @id @default(uuid())
  assinanteId String
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  tecnicoId   String?
  tecnico     User?     @relation("TecnicoOS", fields: [tecnicoId], references: [id])
  tipo        String    // INSTALACAO, REPARO, RETIRADA
  status      String    @default("ABERTA") // ABERTA, EM_EXECUCAO, FINALIZADA, CANCELADA
  descricao       String
  prioridade      String    @default("MEDIA")
  dataAgendamento DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OLT {
  id        String   @id @default(uuid())
  nome      String
  ip        String   @unique
  modelo    String   // INTELBRAS, ZTE, HUAWEI
  comunidade String   @default("public")
  
  onus      ONU[]
}

model ONU {
  id          String   @id @default(uuid())
  oltId       String
  olt         OLT      @relation(fields: [oltId], references: [id])
  serial      String   @unique
  ponPort     Int
  status      String   @default("OFFLINE")
  sinal       String?
}

model NotaFiscal {
  id        String   @id @default(uuid())
  faturaId  String   @unique
  fatura    Fatura   @relation(fields: [faturaId], references: [id])
  numero    String
  xml       String
  status    String   @default("EMITIDA")
}

model AssinanteSVA {
  id          String    @id @default(uuid())
  assinanteId String
  assinante   Assinante @relation(fields: [assinanteId], references: [id])
  svaName     String    // Ex: Paramount+, Noggin, etc
  status      String    @default("ATIVO")
}

model Lead {
  id                String    @id @default(uuid())
  nomeCompleto      String
  cpfCnpj           String?
  rg                String?
  dataNascimento    DateTime?
  email             String?
  telefonePrincipal String
  telefoneSecundario String?
  telefoneWhatsapp  String?
  tipoPessoa        String    @default("PF") // PF, PJ
  
  // Endereço
  cep               String?
  logradouro        String?
  numero            String?
  bairro            String?
  cidade            String?
  uf                String?
  pontoReferencia   String?
  latitude          Float?
  longitude         Float?
  
  // Comercial / Entrada
  canalEntrada      String    // WhatsApp, ligação, indicação, campanha, visita
  campanha          String?   // Origem marketing
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmTerm           String?
  utmContent        String?
  indicador         String?   // Nome de quem indicou
  ipEntrada         String?
  dispositivo       String?
  vendedorId        String?
  vendedor          User?     @relation("VendedorLeads", fields: [vendedorId], references: [id])
  
  // Qualificação
  tipoCliente       String    @default("RESIDENCIAL") // RESIDENCIAL, EMPRESARIAL
  perfilUso         String?   // Básico, Premium, etc
  usoPrincipal      String?   // Streaming, Trabalho, Jogos
  numDispositivos   Int?
  temMEI            Boolean   @default(false)
  scoreQualificacao Int       @default(0)
  interesseDeclarado String?
  interessePlano    String?
  valorPagoAtual    Decimal?  @db.Decimal(10, 2)
  operadoraAtual    String?
  statusQualificacao String   @default("PENDENTE") // PENDENTE, QUALIFICADO, DESQUALIFICADO
  
  // Viabilidade Técnica
  statusViabilidade  String   @default("PENDENTE") // PENDENTE, APROVADA, REPROVADA
  distanciaDistribuidor Float? // Metros
  ctoProxima         String?
  portasDisponiveis  Int?
  obsTecnica         String?
  verificadoPor      String?
  dataVerificacao    DateTime?
  
  // Proposta e Contrato
  statusProposta    String?   // ENVIADA, VISUALIZADA, ACEITA, RECUSADA
  valorProposta     Decimal?  @db.Decimal(10, 2)
  linkContrato      String?
  dataAceite        DateTime?
  
  // Agendamento
  dataInstalacao    DateTime?
  turnoInstalacao   String?   // MANHA, TARDE
  tecnicoId         String?
  numeroOS          String?
  
  // Controle
  observacoes       String?
  perfilComercial   String?   
  decisorIdentificado Boolean @default(false)
  melhorHorario     String?
  tentativasContato Int       @default(0)
  dataProximoContato DateTime?
  dataUltimaInteracao DateTime @default(now())
  isFrio            Boolean   @default(false)
  
  // Metricas
  dataEntrada      DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  stageId           String?
  stage             SalesStage? @relation(fields: [stageId], references: [id])
  history           LeadHistory[]
}

model SalesStage {
  id              String   @id @default(uuid())
  nome            String
  ordem           Int      @default(0)
  isObrigatoria   Boolean  @default(false)
  isConversao     Boolean  @default(false) // Se esta etapa marca o "Ativado"
  slaDias         Int      @default(3)
  cor             String?  @default("#3b82f6")
  
  leads           Lead[]
  createdAt       DateTime @default(now())
}

model LeadHistory {
  id              String   @id @default(uuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id])
  type            String   @default("STAGE_CHANGE") // STAGE_CHANGE, NOTE, CALL, WHATSAPP, EMAIL, TASK
  content         String?
  duration        Int?     // Minutos ou Segundos
  fromStage       String?
  toStage         String?
  responsavelId   String?
  dataEvento      DateTime @default(now())
  motivoPerda     String?
  metadata        Json?    // Detalhes extras (ex: preview msg)
}
